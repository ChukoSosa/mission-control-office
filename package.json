{
  "name": "mission-control-office",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:demo": "node scripts/dev-demo.js",
    "dev:setup": "node scripts/predev.js && next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "setup": "node scripts/setup.js",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:generate": "prisma generate",
    "dummy:set": "node scripts/restore-dummy.js",
    "dummy:restore": "node scripts/restore-dummy.js",
    "demo:db:setup": "node scripts/setup-demo-db.js",
    "demo:db:seed": "tsx scripts/seed-demo-db.ts",
    "demo:dummyset": "tsx scripts/seed-demo-db.ts",
    "demo:db:reset": "npm run demo:db:setup ; npm run demo:db:seed",
    "mc:backlog:review": "tsx scripts/run-backlog-review.ts",
    "dist:build": "node scripts/build-dist.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@prisma/client": "^5.18.0",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-query-devtools": "^5.69.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.2",
    "jose": "^6.2.1",
    "next": "^15.2.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "^15.2.2",
    "postcss": "^8",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.7.1",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
