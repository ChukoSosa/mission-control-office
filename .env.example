# Mission Control Office - Environment Configuration
# Copy this file to .env and fill in the values

# ================================================
# DATABASE
# ================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mission_control"
DEMO_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lucyweb"
MISSION_CONTROL_DEMO_MODE="false"
NEXT_PUBLIC_MISSION_CONTROL_DEMO_MODE="false"

# ================================================
# API
# ================================================
# Base URL for the Mission Control API
# This is where the frontend proxy routes requests
NEXT_PUBLIC_MISSION_CONTROL_API_BASE_URL="http://localhost:3001"

# Backend: who signs and which role this token has
MISSION_CONTROL_API_TOKEN="<<tu-token>>"
MISSION_CONTROL_API_TOKEN_ROLE="operator"
MISSION_CONTROL_API_TOKEN_SUBJECT="human-operator"

# Frontend: same token so apiFetch sends it on requests
NEXT_PUBLIC_MISSION_CONTROL_API_TOKEN="<<tu-token>>"

# Runtime profile
# local-dev    -> editable mock + /web pages visible
# online-demo  -> read-only mock + /web pages visible
# install-local -> real API + mission control only (no /web pages)
NEXT_PUBLIC_RUNTIME_PROFILE="install-local"

# Temporary migration fallback (not recommended for steady-state)
# true  -> allow legacy host/env heuristics when NEXT_PUBLIC_RUNTIME_PROFILE is missing/invalid
# false -> require NEXT_PUBLIC_RUNTIME_PROFILE explicitly (default behavior)
NEXT_PUBLIC_ALLOW_LEGACY_PROFILE_FALLBACK="false"

# Installation profile
# true  -> app-only install (default): blocks /web/*, /web/manual, /web/thank-you
# false -> allow web/marketing pages
APP_ONLY_INSTALL="true"

# Use frontend mock data
# true  -> force mock mode (no DB needed)
# false -> real API mode (default)
NEXT_PUBLIC_USE_MOCK_DATA="false"

# ================================================
# PAYMENT
# ================================================
# Enable/disable the checkout activation button on /web/payment
# true  -> button enabled and checkout can submit
# false -> button disabled and activation is unavailable
NEXT_PUBLIC_ENABLE_PAYMENT_ACTIVATION="false"

# Development license behavior
# bypass     -> no license modal in local development (default)
# accept-any -> show modal but accept any non-empty key in local development
# strict     -> full license validation even in local development
NEXT_PUBLIC_DEV_LICENSE_MODE="bypass"

# ================================================
# OPTIONAL: Avatar Generation
# ================================================
# Used by the generate-avatar API endpoint
# GEMINI_API_KEY="AIzaSyDioWuHWVlcgNQaf9Njr4HDaoCH63jAnhM"
# GEMINI_IMAGE_MODEL="imagegeneration"
# OPENAI_API_KEY="your-openai-api-key"
